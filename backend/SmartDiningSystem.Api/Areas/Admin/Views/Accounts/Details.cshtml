@model SmartDiningSystem.Application.Areas.Admin.Models.AdminAccountDetailsViewModel
@{
    ViewData["Title"] = "Account Details";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">@Model.FullName</h1>
        <p class="text-muted mb-0">Review account details and perform developer control-panel actions.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Accounts" asp-action="Edit" asp-route-id="@Model.Id">Edit Account</a>
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Accounts" asp-action="Index">Back to Accounts</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Username</div>
                <div class="fs-5 fw-semibold"><code>@Model.Username</code></div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Phone</div>
                <div class="fs-5 fw-semibold">@(Model.PhoneNumber ?? "-")</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Email</div>
                <div class="fs-5 fw-semibold">@(Model.Email ?? "-")</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Role</div>
                <div class="fs-5 fw-semibold">@Model.Role</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Status</div>
                <div class="fs-5 fw-semibold">
                    @if (Model.IsActive)
                    {
                        <span class="badge text-bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Inactive</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Phone Verified</div>
                <div class="fs-5 fw-semibold">
                    @if (Model.IsPhoneVerified)
                    {
                        <span class="badge text-bg-info">OTP Verified</span>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">OTP Pending</span>
                    }
                </div>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.RestaurantApprovalStatus))
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase mb-2">Restaurant Approval</div>
                    <div class="fs-5 fw-semibold">
                        @if (string.Equals(Model.RestaurantApprovalStatus, "Approved", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Approved</span>
                        }
                        else if (string.Equals(Model.RestaurantApprovalStatus, "Pending", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning">Pending</span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger">Rejected</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.RestaurantName))
                    {
                        <div class="small text-muted mt-2">@Model.RestaurantName</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.RestaurantRejectionReason))
                    {
                        <div class="small text-danger mt-2">@Model.RestaurantRejectionReason</div>
                    }
                </div>
            </div>
        </div>
    }
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase mb-2">Created</div>
                <div class="fs-5 fw-semibold">@Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body d-flex gap-2 flex-wrap">
        @if (Model.IsActive)
        {
            <form method="post" asp-area="Admin" asp-controller="Accounts" asp-action="Deactivate" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">Deactivate Account</button>
            </form>
        }
        else
        {
            <form method="post" asp-area="Admin" asp-controller="Accounts" asp-action="Activate" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">Activate Account</button>
            </form>
        }

        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
            Delete Account
        </button>
    </div>
</div>

<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Delete Account</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">This action permanently deletes <strong>@Model.FullName</strong> if the account passes all relationship safety checks.</p>
                <p class="text-muted mb-0">Accounts with protected related data will not be deleted, and the system will show a clear error instead.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-area="Admin" asp-controller="Accounts" asp-action="Delete" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete Permanently</button>
                </form>
            </div>
        </div>
    </div>
</div>
