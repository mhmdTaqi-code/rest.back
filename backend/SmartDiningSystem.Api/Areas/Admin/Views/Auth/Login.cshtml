@model SmartDiningSystem.Application.Areas.Admin.Models.AdminLoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Main Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Dining</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-login-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="card border-0 shadow-lg admin-login-card">
                    <div class="card-body p-4 p-md-5">
                        <div class="admin-login-card__eyebrow">Smart Dining</div>
                        <h1 class="admin-login-card__title">Main Admin Login</h1>
                        <p class="admin-login-card__hint">Development credentials: <strong>12</strong> / <strong>12</strong></p>

                        <form method="post" class="needs-validation" novalidate>
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold" asp-for="Username"></label>
                                <input class="form-control form-control-lg" asp-for="Username" autocomplete="username" />
                                <span class="text-danger small" asp-validation-for="Username"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold" asp-for="Password"></label>
                                <input class="form-control form-control-lg" asp-for="Password" autocomplete="current-password" />
                                <span class="text-danger small" asp-validation-for="Password"></span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100">Sign In</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
