<div class="admin-page-header admin-page-header--actions">
    <div>
        <h1 class="h2 mb-1">Accounts</h1>
        <p class="text-muted mb-0">Manage browser-side account operations through the existing Accounts API only.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap admin-toolbar-actions">
        <button type="button" class="btn btn-primary" id="openCreateAccountModal">Create Account</button>
    </div>
</div>

<div id="accountsAlertHost" class="mb-4"></div>

<div class="card shadow-sm admin-surface-card mb-4">
    <div class="card-body">
        <form class="row g-3 align-items-end admin-toolbar-form" id="accountsFilterForm">
            <div class="col-12 col-md-5">
                <label class="form-label" for="accountsSearch">Search</label>
                <input id="accountsSearch" name="search" class="form-control" type="text" placeholder="Name or phone" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="accountsRole">Role</label>
                <select id="accountsRole" name="role" class="form-select">
                    <option value="">All roles</option>
                    <option value="User">User</option>
                    <option value="RestaurantOwner">RestaurantOwner</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex gap-2 admin-toolbar-actions">
                <button type="submit" class="btn btn-outline-primary flex-fill">Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm admin-surface-card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-wrap">
            <div>
                <h2 class="h5 mb-1">Account Directory</h2>
                <p class="text-muted mb-0">The page reads and writes through `/api/accounts` only.</p>
            </div>
            <div id="accountsLoadingState" class="text-muted small d-none">Loading accounts...</div>
        </div>

        <div class="table-responsive admin-table-desktop">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Username</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Phone Verified</th>
                        <th>Restaurant Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="accountsTableBody">
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">Load accounts to begin.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="accountEditorModal" tabindex="-1" aria-labelledby="accountEditorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title h5 mb-1" id="accountEditorModalLabel">Account</h2>
                    <p class="text-muted small mb-0" id="accountEditorModalHint">Create or update without leaving this page.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="accountFormAlertHost" class="mb-3"></div>
                <form id="accountEditorForm" class="row g-3" novalidate>
                    <input type="hidden" id="accountId" />
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="fullName">Full Name</label>
                        <input id="fullName" name="fullName" class="form-control" maxlength="200" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="username">Username</label>
                        <input id="username" name="username" class="form-control" maxlength="50" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="phoneNumber">Phone Number</label>
                        <input id="phoneNumber" name="phoneNumber" class="form-control" maxlength="20" required />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="role">Role</label>
                        <select id="role" name="role" class="form-select" required>
                            <option value="User">User</option>
                            <option value="RestaurantOwner">RestaurantOwner</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 create-only-field">
                        <label class="form-label" for="password">Password</label>
                        <input id="password" name="password" type="password" class="form-control" minlength="6" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12 col-md-6 create-only-field">
                        <label class="form-label" for="confirmPassword">Confirm Password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" minlength="6" />
                        <div class="invalid-feedback"></div>
                    </div>
                    <div class="col-12">
                        <div class="form-text" id="updatePasswordHint">Password changes are not handled from this page. Edit mode keeps the current password unchanged.</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="isActive" name="isActive" checked />
                            <label class="form-check-label" for="isActive">Active account</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" id="isPhoneVerified" name="isPhoneVerified" checked />
                            <label class="form-check-label" for="isPhoneVerified">Phone verified</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="p-3 rounded-4 border bg-light-subtle">
                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
                                <div>
                                    <h3 class="h6 mb-1">Restaurant Owner Fields</h3>
                                    <p class="text-muted small mb-0">Required when creating a `RestaurantOwner`. In edit mode, leave blank to keep current restaurant values unchanged.</p>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-12 col-md-6 restaurant-owner-field">
                                    <label class="form-label" for="restaurantName">Restaurant Name</label>
                                    <input id="restaurantName" name="restaurantName" class="form-control" maxlength="200" />
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-12 col-md-6 restaurant-owner-field">
                                    <label class="form-label" for="restaurantAddress">Restaurant Address</label>
                                    <input id="restaurantAddress" name="restaurantAddress" class="form-control" maxlength="500" />
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-12 restaurant-owner-field">
                                    <label class="form-label" for="restaurantDescription">Restaurant Description</label>
                                    <textarea id="restaurantDescription" name="restaurantDescription" class="form-control" rows="4" maxlength="1000"></textarea>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveAccountButton">Save Account</button>
            </div>
        </div>
    </div>
</div>
