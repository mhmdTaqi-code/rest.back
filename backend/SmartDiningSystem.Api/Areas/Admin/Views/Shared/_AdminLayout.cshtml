<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Dining Main Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var adminPage = ViewData["AdminPage"]?.ToString() ?? currentController;
    }
    <div class="container-fluid px-0">
        <div class="row g-0 min-vh-100">
            <aside class="col-12 col-lg-3 col-xl-2 admin-sidebar">
                <div class="admin-brand mb-4">
                    <div class="admin-brand__eyebrow">Smart Dining</div>
                    <div class="admin-brand__title">Main Admin</div>
                </div>

                <nav class="nav flex-column gap-2">
                    <a class="nav-link admin-nav__link @(string.Equals(adminPage, "Dashboard", StringComparison.OrdinalIgnoreCase) ? "admin-nav__link--active" : null)"
                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <a class="nav-link admin-nav__link @(string.Equals(adminPage, "Accounts", StringComparison.OrdinalIgnoreCase) ? "admin-nav__link--active" : null)"
                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index" asp-route-view="accounts">Accounts</a>
                </nav>
            </aside>

            <div class="col-12 col-lg-9 col-xl-10 admin-main">
                <header class="admin-navbar border-bottom">
                    <div class="admin-navbar__inner">
                        <div>
                            <div class="admin-navbar__title">@ViewData["Title"]</div>
                            <div class="admin-navbar__subtitle">Developer-only control panel</div>
                        </div>
                        <div class="admin-navbar__user text-lg-end">
                            <div class="fw-semibold">@User.Identity?.Name</div>
                            <div class="small text-muted">MainAdmin session</div>
                        </div>
                    </div>
                </header>

                <main class="admin-content">
                    <div class="admin-content__inner">
                        @if (TempData["AdminSuccess"] is string successMessage)
                        {
                            <div class="alert alert-success shadow-sm mb-4" role="alert">@successMessage</div>
                        }

                        @if (TempData["AdminError"] is string errorMessage)
                        {
                            <div class="alert alert-danger shadow-sm mb-4" role="alert">@errorMessage</div>
                        }

                        @RenderBody()
                    </div>
                </main>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
